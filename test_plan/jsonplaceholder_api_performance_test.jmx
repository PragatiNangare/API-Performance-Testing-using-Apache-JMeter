            <hashTree>
              <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PATCH_Update_Post_API" enabled="true">
                <stringProp name="HTTPSampler.domain">${base_URL}</stringProp>
                <stringProp name="HTTPSampler.protocol">https</stringProp>
